<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Audio Player"
        android:textSize="22sp"
        android:textStyle="bold"/>
    <Button
        android:id="@+id/btnOpenAudio"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Open Audio File"
        android:layout_marginBottom="10dp"/>
    <TextView
        android:id="@+id/tvAudioStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Stopped"
        android:layout_marginBottom="10dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnAudioPlay" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Play"/>
        <Button android:id="@+id/btnAudioPause" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pause"/>
        <Button android:id="@+id/btnAudioStop" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Stop"/>
        <Button android:id="@+id/btnAudioRestart" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Restart"/>
    </LinearLayout>
    <!-- VIDEO SECTION -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Video Stream"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>
    <EditText
        android:id="@+id/etVideoUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Video URL"/>
    <Button
        android:id="@+id/btnLoadUrl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Load URL"/>
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_margin="10dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <Button android:id="@+id/btnVideoPlay" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Play"/>
        <Button android:id="@+id/btnVideoPause" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Pause"/>
        <Button android:id="@+id/btnVideoStop" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Stop"/>
        <Button android:id="@+id/btnVideoRestart" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Restart"/>
    </LinearLayout>
</LinearLayout>